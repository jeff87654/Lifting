combo_new_e := combo_new_e + res.new_enum_ms;
combo_new_n := combo_new_n + res.new_normals;
combo_new_o := combo_new_o + res.new_orbits;
agg_h := agg_h + 1;
Print("  norm=", combo_norm, "ms  trad_enum=", combo_trad_e,"ms (",combo_trad_n," normals, ", combo_trad_o, " orbits)  new_enum=", combo_new_e, "ms (", combo_new_n, " normals, ",combo_new_o, " orbits)\n");
agg_norm := agg_norm + combo_norm;
agg_trad_enum := agg_trad_enum + combo_trad_e;
agg_trad_norms := agg_trad_norms + combo_trad_n;
agg_trad_orbits := agg_trad_orbits + combo_trad_o;
agg_new_enum := agg_new_enum + combo_new_e;
agg_new_norms := agg_new_norms + combo_new_n;
agg_new_orbits := agg_new_orbits + combo_new_o;

Print("\n=== [9,3]/[3,1]_[9,29] (M=12, 1 H) ===\n");
S_M := SymmetricGroup(12);
combo_norm := 0; combo_trad_e := 0; combo_trad_n := 0; combo_trad_o := 0;
combo_new_e := 0; combo_new_n := 0; combo_new_o := 0;
H := Group([(1,2,9),(4,5)(7,8),(1,4,7)(2,5,8)(3,6,9),(3,6)(4,7)(5,8),(10,11,12)]);
res := TimeOneH(H, S_M);
combo_norm := combo_norm + res.norm_ms;
combo_trad_e := combo_trad_e + res.trad_enum_ms;
combo_trad_n := combo_trad_n + res.trad_normals;
combo_trad_o := combo_trad_o + res.trad_orbits;
combo_new_e := combo_new_e + res.new_enum_ms;
combo_new_n := combo_new_n + res.new_normals;
combo_new_o := combo_new_o + res.new_orbits;
agg_h := agg_h + 1;
Print("  norm=", combo_norm, "ms  trad_enum=", combo_trad_e,"ms (",combo_trad_n," normals, ", combo_trad_o, " orbits)  new_enum=", combo_new_e, "ms (", combo_new_n, " normals, ",combo_new_o, " orbits)\n");
agg_norm := agg_norm + combo_norm;
agg_trad_enum := agg_trad_enum + combo_trad_e;
agg_trad_norms := agg_trad_norms + combo_trad_n;
agg_trad_orbits := agg_trad_orbits + combo_trad_o;
agg_new_enum := agg_new_enum + combo_new_e;
agg_new_norms := agg_new_norms + combo_new_n;
agg_new_orbits := agg_new_orbits + combo_new_o;

Print("\n=== AGGREGATE ===\n");
Print("Total H:               ", agg_h, "\n");
Print("Total Normalizer time: ", agg_norm, "ms\n");
Print("Traditional (NS+all):  enum=", agg_trad_enum, "ms  ", agg_trad_norms, " normals  ", agg_trad_orbits, " orbits\n");
Print("S3-only (tiered):      enum=", agg_new_enum, "ms  ", agg_new_norms, " normals  ", agg_new_orbits, " orbits\n");
if agg_new_enum > 0 then
    Print("Speedup ratio (enum):  ", Float(agg_trad_enum * 1.0 / agg_new_enum), "x\n");
fi;
LogTo();
QUIT;
