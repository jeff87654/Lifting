combo_trad_e := combo_trad_e + res.trad_enum_ms;
combo_trad_n := combo_trad_n + res.trad_normals;
combo_trad_o := combo_trad_o + res.trad_orbits;
combo_new_e := combo_new_e + res.new_enum_ms;
combo_new_n := combo_new_n + res.new_normals;
combo_new_o := combo_new_o + res.new_orbits;
